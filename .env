# =============================================
# 应用配置
# =============================================

# 应用标题
VITE_APP_TITLE=Meeo Plan 管理平台

# 基础路径（部署到子目录时需要修改）
VITE_BASE_PATH=/

# API 基础路径
VITE_BASE_API=/api

# 开发服务器配置
VITE_PORT=5173
VITE_OPEN=true

# API 地址
VITE_API_URL=http://localhost:8080
VITE_UPLOAD_URL=http://localhost:8080/upload

# 输出目录
VITE_OUT_DIR=dist

# =============================================
# 构建配置
# =============================================

# 是否生成 sourceMap
VITE_SOURCEMAP=false

# 是否移除 console.log
VITE_DROP_CONSOLE=false

# 是否移除 debugger
VITE_DROP_DEBUGGER=false

# =============================================
# 功能开关
# =============================================

# 租户模式
VITE_APP_TENANT_ENABLE=false

# 验证码
VITE_APP_CAPTCHA_ENABLE=true

# 请求加密
VITE_APP_API_ENCRYPT_ENABLE=false
VITE_APP_CRYPTO_KEY=your-secret-key-change-in-production

# =============================================
# 第三方服务配置
# =============================================

# CDN 地址
VITE_CDN_URL=

# 错误上报
VITE_ERROR_REPORT_URL=

# 性能监控
VITE_PERFORMANCE_REPORT_URL=

# Sentry DSN
VITE_SENTRY_DSN=

# =============================================
# DeepSeek API 配置
# =============================================

# DeepSeek API Key（用于AI方案生成功能）
VITE_DEEPSEEK_API_KEY=sk-53309b4654d2430d90933d9af520d392

# =============================================
# PWA 配置
# =============================================

VITE_ENABLE_PWA=false
VITE_ENABLE_SERVICE_WORKER=false
